# ─── OpenAI ────────────────────────────────────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
# Used for: agent chat (gpt-4o-mini) + RAG embeddings (text-embedding-3-small)
OPENAI_API_KEY=sk-...

# ─── Supabase ──────────────────────────────────────────────────────────────────
# Get from: https://supabase.com/dashboard → project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # Server-only: bypasses Row Level Security for RAG writes

# ─── Tavily (Web Search MCP) ────────────────────────────────────────────────────
# Get from: https://tavily.com
TAVILY_API_KEY=tvly-...

# ─── App Config ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
